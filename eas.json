{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "staging": {
      "distribution": "store",
      "channel": "staging",
      "ios": {
        "bundleIdentifier": "com.stakemate.pokerroll.staging",
        "buildConfiguration": "Release"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {},
    "staging": {
      "ios": {
        "appleId": "brijeshnegi.86@gmail.com",
        "ascAppId": "YOUR_STAGING_APP_ID",
        "bundleIdentifier": "com.stakemate.pokerroll.staging"
      }
    }
  }
}
